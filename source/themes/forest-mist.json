{
	"--base": "calc(1rem/2)",
	"--base-font-size": "17px",
	"--container-width-multiplier": "160",
	"--container-width": "calc(var(--base) * var(--container-width-multiplier))",
	"--container-width-wide-multiplier": "1.25",
	"--container-width-wide": "calc(var(--container-width) * var(--container-width-wide-multiplier))",
	"--border-radius": "2",
	"--corner-shape": "scoop",
	"--font-family-base": "\"Roboto\", sans-serif",
	"--font-family-heading": "var(--font-family-base)",
	"--font-family-code": "\"Fira Sans\", \"Monaco\", \"Consolas\", \"Menlo\", \"Lucida Console\", \"Courier New\", \"Courier\", \"Console\"",
	"--font-size-scale-ratio": "1.12",
	"--font-weight-normal": "400",
	"--font-weight-medium": "500",
	"--font-weight-bold": "700",
	"--line-height-base": "1.68",
	"--line-height-heading": "1.32",
	"--letter-spacing-base": "0.002em",
	"--font-size-80": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), -2))",
	"--font-size-90": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), -1))",
	"--font-size-100": "var(--base-font-size)",
	"--font-size-200": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 1))",
	"--font-size-300": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 2))",
	"--font-size-400": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 3))",
	"--font-size-500": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 4))",
	"--font-size-600": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 5))",
	"--font-size-700": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 6))",
	"--font-size-800": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 7))",
	"--border-width": "0.18",
	"--color--border-mix-amount": "10%",
	"--space": "1.3",
	"--outer-space": "2.4",
	"--shadow-color": "rgba(28, 47, 36, 0.1)",
	"--shadow-amount": "0.75",
	"--color--primary": "#3f7a58",
	"--color--primary-contrast": "#f3fff8",
	"--color--primary-border": "color-mix(in srgb, var(--color--primary-contrast) var(--color--border-mix-amount), var(--color--primary))",
	"--color--primary-alt": "color-mix(in srgb, var(--color--primary-contrast) var(--color--alt-mix-amount), var(--color--primary))",
	"--color--secondary": "#628f77",
	"--color--secondary-contrast": "#163123",
	"--color--secondary-border": "color-mix(in srgb, var(--color--secondary-contrast) var(--color--border-mix-amount), var(--color--secondary))",
	"--color--secondary-alt": "color-mix(in srgb, var(--color--secondary-contrast) var(--color--alt-mix-amount), var(--color--secondary))",
	"--color--alt-mix-amount": "4%",
	"--color--background": "#eef7f1",
	"--color--background-contrast": "#203129",
	"--color--background-contrast-muted": "#5b7264",
	"--color--background-border": "color-mix(in srgb, var(--color--background-contrast) var(--color--border-mix-amount), var(--color--background))",
	"--color--surface": "#f9fffb",
	"--color--surface-contrast": "#24382d",
	"--color--surface-contrast-muted": "#6a8172",
	"--color--surface-border": "color-mix(in srgb, var(--color--surface-contrast) var(--color--border-mix-amount), var(--color--surface))",
	"--color--surface-alt": "color-mix(in srgb, var(--color--surface-contrast-muted) var(--color--alt-mix-amount), var(--color--surface))",
	"--color--focus": "#24593d",
	"--color--alpha": "rgba(18, 38, 25, 0.2)",
	"--color--alpha-contrast": "#f3faf5",
	"--color--alpha-border": "color-mix(in srgb, var(--color--alpha-contrast) var(--color--border-mix-amount), var(--color--alpha))",
	"--color--success": "#2f8a56",
	"--color--success-contrast": "#ecfff3",
	"--color--success-border": "color-mix(in srgb, var(--color--success-contrast) var(--color--border-mix-amount), var(--color--success))",
	"--color--warning": "#a77b2c",
	"--color--warning-contrast": "#2b210d",
	"--color--warning-border": "color-mix(in srgb, var(--color--warning-contrast) var(--color--border-mix-amount), var(--color--warning))",
	"--color--danger": "#a24f4f",
	"--color--danger-contrast": "#fff5f5",
	"--color--danger-border": "color-mix(in srgb, var(--color--danger-contrast) var(--color--border-mix-amount), var(--color--danger))",
	"--color--info": "#327a95",
	"--color--info-contrast": "#f1fbff",
	"--color--info-border": "color-mix(in srgb, var(--color--info-contrast) var(--color--border-mix-amount), var(--color--info))"
}
