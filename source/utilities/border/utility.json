{
    "$schema": "../../utility-schema.json",
    "apiVersion": 1,
    "name": "Border",
    "slug": "border",
    "entries": {
        "borders-colors": {
            "format": "u-border__color--name",
            "modifiers": {
                "name": "primary, secondary, success, danger, info, warning"
            },
            "description": {
                "name": "Sets the color of elements borders"
            },
            "responsive": false
        },
        "borders": {
            "format": "u-border__side--width",
            "modifiers": {
                "side": "top, left, right, bottom",
                "width": "0, 1, 2"
            },
            "description": {
                "side": "Specify specific side",
                "width": "Sets the width of elements borders"
            },
            "responsive": true
        },
        "borders-sides": {
            "format": "u-border__side--width",
            "modifiers": {
                "side": "top. left, right, bottom",
                "width": "0, 1, 2"
            },
            "description": {
                "side": "Specify specific side",
                "width": "Sets the width of elements borders"
            },
            "responsive": true
        },
        "borders-more": {
            "format": "u-border__style--name",
            "modifiers": {
                "name": "dashed, dotted, double, groove, ridge, inset, outset"
            },
            "description": {
                "name": "Sets the style of elements borders"
            }
        }
    },
    "icon": "border_style"
}
