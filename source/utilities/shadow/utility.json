{
    "$schema": "../../utility-schema.json",
    "apiVersion": 1,
    "name": "Shadow",
    "slug": "shadow",
    "entries": {
        "box-shadow": {
            "format": "u-shadow--{number}",
            "modifiers": {
                "level": "1, 2, 3, 4, 5"
            },
            "description": {
                "level": "Applies a box-shadow to the element based on the specified level. Higher levels correspond to more pronounced shadows."
            },
            "responsive": false,
            "examples": [
                {
                    "view": "box-shadow-levels",
                    "css": "box-shadow-levels.css"
                }
            ]
        }
    },
    "icon": "layers"
}
