{
	"$schema": "../design-tokens-schema.json",
	"name": "Design System",
	"version": "1.0.0",
	"categories": [
		{
			"id": "base",
			"label": "Base",
			"description": "Foundation values that drive spacing, radius, and typography scales.",
			"settings": [
				{
					"variable": "--base",
					"label": "Base Unit",
					"description": "Main unit that drives radius and spacing scales.",
					"type": "range",
					"default": "calc(1rem/2)",
					"unit": "px",
					"locked": true
				},
				{
					"variable": "--base-font-size",
					"label": "Base Font Size",
					"description": "Root font size. All typographic sizes derive from this.",
					"type": "select",
					"default": "1rem",
					"unit": "rem",
					"options": [
						{
							"value": "16px",
							"label": "Standard"
						},
						{
							"value": "18px",
							"label": "Large"
						}
					]
				}
			]
		},
		{
			"id": "layout",
			"label": "Layout",
			"description": "Tokens for layout widths",
			"settings": [
				{
					"variable": "--container-width-multiplier",
					"label": "Container Width Multiplier",
					"description": "Multiplier that drives container widths.",
					"type": "range",
					"default": 160,
					"min": 112,
					"max": 206,
					"step": 2,
					"unit": "",
					"locked": false
				},
				{
					"variable": "--container-width",
					"label": "Container Width",
					"description": "Main unit that drives container widths.",
					"type": "range",
					"default": "calc(var(--base) * var(--container-width-multiplier))",
					"unit": "",
					"locked": true
				},
				{
					"variable": "--container-width-wide-multiplier",
					"label": "Container Wide Width Multiplier",
					"description": "Multiplier for wide container width.",
					"type": "range",
					"default": 1.25,
					"unit": "",
					"min": 1,
					"max": 3,
					"step": 0.25,
					"locked": false
				},
				{
					"variable": "--container-width-wide",
					"label": "Container Wide Width",
					"description": "Max width for wide containers.",
					"type": "range",
					"default": "calc(var(--container-width) * var(--container-width-wide-multiplier))",
					"unit": "",
					"locked": true
				}
			]
		},
		{
			"id": "radius",
			"label": "Radius",
			"description": "Border radius and corner shape style.",
			"settings": [
				{
					"variable": "--border-radius",
					"label": "Border Radius",
					"type": "range",
					"default": 1,
					"unit": "",
					"min": 0,
					"max": 5,
					"step": 0.25
				},
				{
					"variable": "--corner-shape",
					"label": "Corner Shape",
					"type": "select",
					"default": "rounded",
					"options": [
						{
							"value": "square",
							"label": "Square"
						},
						{
							"value": "rounded",
							"label": "Rounded"
						},
						{
							"value": "squircle",
							"label": "Squircle"
						},
						{
							"value": "circular",
							"label": "Circular"
						},
						{
							"value": "bevel",
							"label": "Bevel"
						},
						{
							"value": "scoop",
							"label": "Scoop"
						}
					]
				}
			]
		},
		{
			"id": "typography",
			"label": "Typography",
			"description": "Font families, type scale, weights, and line heights.",
			"settings": [
				{
					"variable": "--font-family-base",
					"label": "Body Font",
					"type": "font",
					"default": "\"Roboto\", sans-serif"
				},
				{
					"variable": "--font-family-heading",
					"label": "Heading Font",
					"description": "Falls back to body font if not set.",
					"type": "font",
					"default": "var(--font-family-base)"
				},
				{
					"variable": "--font-family-code",
					"label": "Code Font",
					"type": "font",
					"default": "\"Fira Sans\", \"Monaco\", \"Consolas\", \"Menlo\", \"Lucida Console\", \"Courier New\", \"Courier\", \"Console\"",
					"locked": true
				},
				{
					"variable": "--font-size-scale-ratio",
					"label": "Type Scale",
					"description": "Multiplier that generates all font sizes from the base.",
					"type": "select",
					"default": "1.250",
					"options": [
						{
							"value": "1.067",
							"label": "Minor Second"
						},
						{
							"value": "1.125",
							"label": "Major Second"
						},
						{
							"value": "1.200",
							"label": "Minor Third"
						},
						{
							"value": "1.250",
							"label": "Major Third"
						},
						{
							"value": "1.333",
							"label": "Perfect Fourth"
						}
					]
				},
				{
					"variable": "--font-weight-normal",
					"label": "Normal Weight",
					"type": "select",
					"default": "400",
					"options": [
						{
							"value": "100",
							"label": "Thin"
						},
						{
							"value": "200",
							"label": "Extra Light"
						},
						{
							"value": "300",
							"label": "Light"
						},
						{
							"value": "400",
							"label": "Regular"
						},
						{
							"value": "500",
							"label": "Medium"
						},
						{
							"value": "600",
							"label": "Semi Bold"
						}
					]
				},
				{
					"variable": "--font-weight-medium",
					"label": "Medium Weight",
					"type": "select",
					"default": "500",
					"options": [
						{
							"value": "400",
							"label": "Regular"
						},
						{
							"value": "500",
							"label": "Medium"
						},
						{
							"value": "600",
							"label": "Semi Bold"
						},
						{
							"value": "700",
							"label": "Bold"
						}
					]
				},
				{
					"variable": "--font-weight-bold",
					"label": "Bold Weight",
					"type": "select",
					"default": "700",
					"options": [
						{
							"value": "600",
							"label": "Semi Bold"
						},
						{
							"value": "700",
							"label": "Bold"
						},
						{
							"value": "800",
							"label": "Extra Bold"
						},
						{
							"value": "900",
							"label": "Black"
						}
					]
				},
				{
					"variable": "--line-height-base",
					"label": "Body Line Height",
					"type": "range",
					"default": "1.625",
					"min": 1.0,
					"max": 2.0,
					"step": 0.025
				},
				{
					"variable": "--line-height-heading",
					"label": "Heading Line Height",
					"type": "range",
					"default": "1.33",
					"min": 1.0,
					"max": 1.8,
					"step": 0.01
				},
				{
					"variable": "--letter-spacing-base",
					"label": "Letter Spacing",
					"type": "range",
					"default": "0",
					"unit": "em",
					"min": -0.05,
					"max": 0.2,
					"step": 0.005
				}
			]
		},
		{
			"id": "font-sizes",
			"label": "Font Sizes",
			"description": "Computed font size scale derived from base font size and type scale ratio.",
			"settings": [
				{
					"variable": "--font-size-80",
					"label": "Font Size 80",
					"description": "Two steps below base in the type scale.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), -2))",
					"locked": true
				},
				{
					"variable": "--font-size-90",
					"label": "Font Size 90",
					"description": "One step below base in the type scale.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), -1))",
					"locked": true
				},
				{
					"variable": "--font-size-100",
					"label": "Font Size 100",
					"description": "Base font size.",
					"type": "range",
					"default": "var(--base-font-size)",
					"locked": true
				},
				{
					"variable": "--font-size-200",
					"label": "Font Size 200",
					"description": "One step above base in the type scale. Equivalent to h6/subtitle.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 1))",
					"locked": true
				},
				{
					"variable": "--font-size-300",
					"label": "Font Size 300",
					"description": "Two steps above base in the type scale. Equivalent to h5.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 2))",
					"locked": true
				},
				{
					"variable": "--font-size-400",
					"label": "Font Size 400",
					"description": "Three steps above base in the type scale. Equivalent to h4.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 3))",
					"locked": true
				},
				{
					"variable": "--font-size-500",
					"label": "Font Size 500",
					"description": "Four steps above base in the type scale. Equivalent to h3.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 4))",
					"locked": true
				},
				{
					"variable": "--font-size-600",
					"label": "Font Size 600",
					"description": "Five steps above base in the type scale. Equivalent to h2.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 5))",
					"locked": true
				},
				{
					"variable": "--font-size-700",
					"label": "Font Size 700",
					"description": "Six steps above base in the type scale. Equivalent to h1.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 6))",
					"locked": true
				},
				{
					"variable": "--font-size-800",
					"label": "Font Size 800",
					"description": "Seven steps above base in the type scale. Larger than h1.",
					"type": "range",
					"default": "calc(var(--base-font-size) * pow(var(--font-size-scale-ratio), 7))",
					"locked": true
				}
			]
		},
		{
			"id": "borders",
			"label": "Borders",
			"description": "Border width tokens for UI elements.",
			"settings": [
				{
					"variable": "--border-width",
					"label": "Size",
					"type": "range",
					"default": "0.125",
					"unit": "",
					"min": 0,
					"max": 4,
					"step": 0.125
				},
				{
					"variable": "--color--border-mix-amount",
					"label": "Border Mix Amount",
					"description": "Controls contrast intensity used when generating companion border colors.",
					"type": "range",
					"default": "10%",
					"min": 0,
					"max": 100,
					"step": 1,
					"unit": "%"
				}
			]
		},
		{
			"id": "space",
			"label": "Spacing",
			"description": "Spacing tokens for UI elements.",
			"settings": [
				{
					"variable": "--space",
					"label": "Size",
					"description": "Base spacing unit. Used for padding and margin inside components.",
					"type": "range",
					"default": 1,
					"unit": "",
					"min": 0,
					"max": 3,
					"step": 0.25
				},
				{
					"variable": "--outer-space",
					"label": "Outer Space",
					"description": "Spacing between components. Use --space for spacing inside components.",
					"type": "range",
					"default": 1,
					"unit": "",
					"min": 0,
					"max": 3,
					"step": 0.25
				}
			]
		},
		{
			"id": "shadows",
			"label": "Shadows",
			"description": "Global shadow multipliers and color.",
			"settings": [
				{
					"variable": "--shadow-color",
					"label": "Shadow Color",
					"type": "rgba",
					"default": "rgba(0, 0, 0, 0.1)"
				},
				{
					"variable": "--shadow-amount",
					"label": "Drop Shadow Intensity",
					"description": "Multiplier for elevation shadows. 0 = none, 1 = default.",
					"type": "range",
					"default": "0.7",
					"min": 0,
					"max": 2,
					"step": 0.1
				}
			]
		},
		{
			"id": "colors-brand",
			"label": "Brand Colors",
			"description": "Primary, secondary, and accent brand colors with contrast pairs.",
			"settings": [
				{
					"variable": "--color--primary",
					"label": "Primary",
					"type": "color",
					"default": "#2d2d2d",
					"contrast": "--color--primary-contrast"
				},
				{
					"variable": "--color--primary-contrast",
					"label": "Primary Contrast",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--primary-border",
					"label": "Primary Border",
					"description": "Manual companion token for primary border and hover states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--primary-contrast) var(--color--border-mix-amount), var(--color--primary))"
				},
				{
					"variable": "--color--primary-alt",
					"label": "Primary Alt",
					"description": "Manual companion token for subtle primary surfaces.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--primary-contrast) var(--color--alt-mix-amount), var(--color--primary))"
				},
				{
					"variable": "--color--secondary",
					"label": "Secondary",
					"type": "color",
					"default": "#6e6e6e",
					"contrast": "--color--secondary-contrast"
				},
				{
					"variable": "--color--secondary-contrast",
					"label": "Secondary Contrast",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--secondary-border",
					"label": "Secondary Border",
					"description": "Manual companion token for secondary border and hover states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--secondary-contrast) var(--color--border-mix-amount), var(--color--secondary))"
				},
				{
					"variable": "--color--secondary-alt",
					"label": "Secondary Alt",
					"description": "Manual companion token for subtle secondary surfaces.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--secondary-contrast) var(--color--alt-mix-amount), var(--color--secondary))"
				}
			]
		},
		{
			"id": "colors-layout",
			"label": "Layout Colors",
			"description": "Background and surface colors.",
			"settings": [
				{
					"variable": "--color--alt-mix-amount",
					"label": "Alt Mix Amount",
					"description": "Controls contrast intensity used when generating companion alt colors.",
					"type": "range",
					"default": "4%",
					"min": 0,
					"max": 20,
					"step": 1,
					"unit": "%"
				},
				{
					"variable": "--color--background",
					"label": "Background",
					"type": "color",
					"default": "#f5f5f5",
					"contrast": ["--color--background-contrast", "--color--background-contrast-muted"]
				},
				{
					"variable": "--color--background-contrast",
					"label": "Background Contrast",
					"description": "Used for text and icons on background with less contrast.",
					"type": "color",
					"default": "#2d2d2d"
				},
				{
					"variable": "--color--background-contrast-muted",
					"label": "Background Contrast Muted",
					"description": "Used for text and icons on background with less contrast.",
					"type": "color",
					"default": "#6e6e6e"
				},
				{
					"variable": "--color--background-border",
					"label": "Background Border",
					"description": "Manual companion token for borders on background surfaces.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--background-contrast) var(--color--border-mix-amount), var(--color--background))"
				},
				{
					"variable": "--color--surface",
					"label": "Surface",
					"type": "color",
					"default": "#ffffff",
					"contrast": ["--color--surface-contrast", "--color--surface-contrast-muted"]
				},
				{
					"variable": "--color--surface-contrast",
					"label": "Surface Contrast",
					"description": "Used for text and icons on surface backgrounds with less contrast.",
					"type": "color",
					"default": "#2d2d2d"
				},
				{
					"variable": "--color--surface-contrast-muted",
					"label": "Surface Contrast Muted",
					"description": "Used for text and icons on surface backgrounds with less contrast.",
					"type": "color",
					"default": "#6e6e6e"
				},
				{
					"variable": "--color--surface-border",
					"label": "Surface Border",
					"description": "Manual companion token for borders on surface elements.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--surface-contrast) var(--color--border-mix-amount), var(--color--surface))"
				},
				{
					"variable": "--color--surface-alt",
					"label": "Surface Alt",
					"description": "Manual companion token for subtle surface backgrounds.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--surface-contrast-muted) var(--color--alt-mix-amount), var(--color--surface))"
				}
			]
		},
		{
			"id": "colors-ui",
			"label": "UI Colors",
			"description": "Borders, focus, and interactive states.",
			"settings": [
				{
					"variable": "--color--focus",
					"label": "Focus",
					"type": "color",
					"default": "#4d90fe"
				},
				{
					"variable": "--color--alpha",
					"label": "Alpha Color",
					"description": "Used for overlays. Includes opacity — set both color and alpha together.",
					"type": "rgba",
					"default": "rgba(0, 0, 0, 0.1)"
				},
				{
					"variable": "--color--alpha-contrast",
					"label": "Alpha Contrast",
					"description": "Used for text and icons on alpha overlays.",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--alpha-border",
					"label": "Alpha Border",
					"description": "Manual companion token for alpha overlay border states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--alpha-contrast) var(--color--border-mix-amount), var(--color--alpha))"
				}
			]
		},
		{
			"id": "colors-state",
			"label": "State Colors",
			"description": "Feedback colors for success, warning, error, and info.",
			"settings": [
				{
					"variable": "--color--success",
					"label": "Success",
					"type": "color",
					"default": "#4caf50",
					"contrast": "--color--success-contrast"
				},
				{
					"variable": "--color--success-contrast",
					"label": "Success Contrast",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--success-border",
					"label": "Success Border",
					"description": "Auto-generated companion token for success border and emphasis states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--success-contrast) var(--color--border-mix-amount), var(--color--success))"
				},
				{
					"variable": "--color--warning",
					"label": "Warning",
					"type": "color",
					"default": "#ffb300",
					"contrast": "--color--warning-contrast"
				},
				{
					"variable": "--color--warning-contrast",
					"label": "Warning Contrast",
					"type": "color",
					"default": "#2d2d2d"
				},
				{
					"variable": "--color--warning-border",
					"label": "Warning Border",
					"description": "Auto-generated companion token for warning border and emphasis states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--warning-contrast) var(--color--border-mix-amount), var(--color--warning))"
				},
				{
					"variable": "--color--danger",
					"label": "Danger",
					"type": "color",
					"default": "#e53935",
					"contrast": "--color--danger-contrast"
				},
				{
					"variable": "--color--danger-contrast",
					"label": "Danger Contrast",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--danger-border",
					"label": "Danger Border",
					"description": "Manual companion token for danger border and emphasis states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--danger-contrast) var(--color--border-mix-amount), var(--color--danger))"
				},
				{
					"variable": "--color--info",
					"label": "Info",
					"type": "color",
					"default": "#039be5",
					"contrast": "--color--info-contrast"
				},
				{
					"variable": "--color--info-contrast",
					"label": "Info Contrast",
					"type": "color",
					"default": "#ffffff"
				},
				{
					"variable": "--color--info-border",
					"label": "Info Border",
					"description": "Auto-generated companion token for info border and emphasis states.",
					"type": "color",
					"locked": true,
					"default": "color-mix(in srgb, var(--color--info-contrast) var(--color--border-mix-amount), var(--color--info))"
				}
			]
		}
	]
}
