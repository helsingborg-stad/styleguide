{
	"title": "JSON schema for Helsingborg Styleguide Utilities",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string"
		},
		"apiVersion": {
			"description": "The version of the utility API this configuration uses.",
			"type": "integer",
			"const": 1
		},
		"name": {
			"description": "Display title of the utility group.",
			"type": "string"
		},
		"slug": {
			"description": "Utility group slug.",
			"type": "string",
			"pattern": "^[a-z][a-z0-9-]*$"
		},
		"entries": {
			"description": "A dictionary of utility documentation entries keyed by config identifier.",
			"type": "object",
			"minProperties": 1,
			"patternProperties": {
				"^[a-z0-9_-]+$": {
					"$ref": "#/$defs/utilityEntry"
				}
			},
			"additionalProperties": false
		}
	},
	"required": [
		"apiVersion",
		"name",
		"slug",
		"entries"
	],
	"additionalProperties": false,
	"$defs": {
		"utilityEntry": {
			"type": "object",
			"properties": {
				"title": {
					"type": "string"
				},
				"summary": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"description": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					}
				},
				"modifiers": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					}
				},
				"format": {
					"type": "string"
				},
				"responsive": {
					"type": "boolean"
				},
				"examples": {
					"type": [
						"array",
						"object",
						"string"
					]
				}
			},
			"required": [
				"description"
			],
			"additionalProperties": false
		}
	}
}
